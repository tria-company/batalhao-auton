# --- LLM: escolha UM dos dois ---
# (A) Azure OpenAI — tem prioridade quando AZURE_OPENAI_ENDPOINT estiver preenchido.
AZURE_OPENAI_ENDPOINT=https://<seu-recurso>.cognitiveservices.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini

# (B) OpenAI direta — usada apenas se AZURE_OPENAI_ENDPOINT estiver vazio.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini
# Override opcional da triagem (so OpenAI direta): OPENAI_MODEL_ORGANIZADOR=gpt-4.1-nano

# --- Supabase (service role: escrita server-side, bypassa RLS — NUNCA expor no cliente) ---
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...

# --- Parametros do pipeline ---
# Quantos posts por (perfil, rede) — PRD usa 50.
POSTS_PER_PROFILE=50
# Cambio usado APENAS para exibir custos em BRL (o custo gravado no banco fica em USD).
USD_BRL_RATE=6.0

# --- Scraper externo (popula scrappers_contents) ---
# Token da Apify (https://console.apify.com/account/integrations). Necessario p/ Instagram e TikTok.
APIFY_TOKEN=
# Actor IDs (formato `username~actor-name`). Os defaults sao actors publicos da Apify.
APIFY_INSTAGRAM_ACTOR=apify~instagram-profile-scraper
APIFY_TIKTOK_ACTOR=clockworks~tiktok-scraper
# yt-dlp deve estar no PATH (no VPS ja foi instalado em /usr/local/bin/yt-dlp).
YT_DLP_BIN=yt-dlp
